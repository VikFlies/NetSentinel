{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Lancer NetSentinel",
            "type": "shell",
            "command": "${workspaceFolder}/mvnw.cmd compile exec:java",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        },
        {
            "label": "Lancer les tests",
            "type": "shell",
            "command": "${workspaceFolder}/mvnw.cmd test",
            "group": "test",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        }
    ]
}
